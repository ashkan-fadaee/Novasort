<Application
    x:Class="NovaSortPro.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:NovaSortPro.Common"
    xmlns:local="using:NovaSortPro">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ViewModel Locator -->
            <local:ViewModelLocator x:Key="Locator" />

            <!-- Converters -->
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <converters:PauseResumeLabelConverter x:Key="PauseResumeLabelConverter" />
            <converters:StringFormatConverter x:Key="StringFormatConverter" />

            <!-- Custom Font Styles -->
            <FontFamily x:Key="PersianFontFamily">/Assets/Fonts/Vazirmatn-Regular.ttf#Vazirmatn</FontFamily>

            <!-- Theme Transitions -->
            <TransitionCollection x:Key="AppThemeTransitions">
                <NavigationThemeTransition />
            </TransitionCollection>
        </ResourceDictionary>
    </Application.Resources>
</Application>
