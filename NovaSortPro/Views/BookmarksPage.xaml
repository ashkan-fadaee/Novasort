<Page
    x:Class="NovaSortPro.Views.BookmarksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NovaSortPro.Views"
    xmlns:models="using:NovaSortPro.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24" RowSpacing="16" FlowDirection="{Binding Main.LayoutDirection, Source={StaticResource Locator}, FallbackValue=LeftToRight}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Bookmarks &amp; Workspaces" FontSize="28" FontWeight="SemiBold"/>
            <TextBlock Text="Pin your most frequent folders, track recent locations, and establish favorite shortcuts safely offline." FontSize="14" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
        </StackPanel>

        <!-- Add Favorite Panel -->
        <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Text="{Binding NewFolderPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter or paste folder path to bookmark..." Header="Folder Path"/>
                <TextBox Grid.Column="1" Text="{Binding NewFolderName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Optional custom name (e.g. Work Downloads)..." Header="Friendly Label"/>
                <Button Grid.Column="2" Content="Browse..." Click="OnBrowseFolderClick" Style="{StaticResource DefaultButtonStyle}" VerticalAlignment="Bottom" Height="38"/>
                <Button Grid.Column="3" Content="Add Bookmark" Click="OnAddBookmarkClick" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Bottom" Height="38"/>
            </Grid>
        </Border>

        <!-- Bookmarks Lists -->
        <Grid Grid.Row="2" ColumnSpacing="16" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Favorites -->
            <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="My Favorite Folders" FontSize="18" FontWeight="Medium"/>
                    <ListView Grid.Row="1" ItemsSource="{Binding Favorites}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Bookmark">
                                <Grid Padding="8,4" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{x:Bind Path}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Remove" Click="OnDeleteBookmarkClick" Style="{StaticResource DefaultButtonStyle}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Recents -->
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Recently Sorted Locations" FontSize="18" FontWeight="Medium"/>
                    <ListView Grid.Row="1" ItemsSource="{Binding Recents}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Bookmark">
                                <Grid Padding="8,4" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{x:Bind Path}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Remove" Click="OnDeleteBookmarkClick" Style="{StaticResource DefaultButtonStyle}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
