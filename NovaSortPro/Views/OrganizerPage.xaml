<Page
    x:Class="NovaSortPro.Views.OrganizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NovaSortPro.Views"
    xmlns:models="using:NovaSortPro.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!-- Inline Boolean to Visibility Converter Simulation using Double/Opacity or simple converters -->
    </Page.Resources>

    <Grid Padding="24" RowSpacing="16" FlowDirection="{Binding Main.LayoutDirection, Source={StaticResource Locator}, FallbackValue=LeftToRight}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Smart Organizer" FontSize="28" FontWeight="SemiBold"/>
            <TextBlock Text="Analyze, Preview, and Smart-Sort your local workspace securely offline." FontSize="14" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
        </StackPanel>

        <!-- Control Bar -->
        <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="PathTextBox" Grid.Column="0" Text="{Binding TargetFolderPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter or paste folder path to scan..." VerticalAlignment="Center" Header="Target Folder"/>
                <Button Grid.Column="1" Content="Browse..." VerticalAlignment="Bottom" Click="OnBrowseFolderClick" Style="{StaticResource AccentButtonStyle}" Height="38"/>
                <Button Grid.Column="2" Content="Scan Directory" VerticalAlignment="Bottom" Click="OnScanClick" Style="{StaticResource AccentButtonStyle}" Height="38"/>
            </Grid>
        </Border>

        <!-- Main Preview List & Side Settings -->
        <Grid Grid.Row="2" ColumnSpacing="16" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- File List -->
            <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Files Preview" FontSize="18" FontWeight="Medium" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Width="200" Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Search files..." Header=""/>
                    </Grid>

                    <ListView Grid.Row="1" ItemsSource="{Binding FilesPreview}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:FileItem">
                                <Grid ColumnSpacing="12" Padding="8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="Medium"/>
                                        <TextBlock Text="{x:Bind FullPath}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{x:Bind SizeDisplay}" VerticalAlignment="Center" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <TextBlock Text="{x:Bind Category}" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Destination Category" FontSize="10" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="3" Text="{x:Bind Status}" VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Side Configuration & Stats -->
            <StackPanel Grid.Column="1" Spacing="12">
                <!-- Statistics -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Operation Summary" FontSize="18" FontWeight="Medium"/>
                        <TextBlock Text="{Binding TotalFilesLabel}"/>
                        <TextBlock Text="{Binding TotalSizeLabel}"/>
                        <TextBlock Text="{Binding EstTimeLabel}"/>
                    </StackPanel>
                </Border>

                <!-- Conflict Rules -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Conflict Resolution" FontSize="18" FontWeight="Medium"/>
                        <RadioButtons x:Name="ConflictOptionGroup" SelectionChanged="OnConflictOptionChanged">
                            <RadioButton Content="Rename conflict files" IsChecked="True"/>
                            <RadioButton Content="Replace (Overwrite) destination"/>
                            <RadioButton Content="Skip conflict files"/>
                            <RadioButton Content="Ask Every Time"/>
                        </RadioButtons>
                    </StackPanel>
                </Border>

                <!-- Action Button -->
                <Button Content="Organize &amp; Clean Workspace" Click="OnOrganizeClick" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Height="50" FontSize="16" FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>

        <!-- Progress Queue Manager -->
        <Border Grid.Row="3" x:Name="ProgressBorder" Visibility="Collapsed" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="Organizing local files in progress..." FontWeight="Medium"/>
                    <ProgressBar x:Name="SortProgressBar" Value="{Binding ProgressValue}" Maximum="100" Height="8"/>
                </StackPanel>
                <Button Grid.Column="1" x:Name="PauseResumeBtn" Content="Pause" Click="OnPauseResumeClick" Width="100"/>
                <Button Grid.Column="2" Content="Cancel" Click="OnCancelClick" Style="{StaticResource DefaultButtonStyle}" Width="100"/>
            </Grid>
        </Border>
    </Grid>
</Page>
